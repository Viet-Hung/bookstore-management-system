@model List<Bookstore.Module.Orders.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Orders</h1>
        <a asp-area="Orders" asp-controller="Orders" asp-action="Create" class="btn btn-primary">
            Create Order
        </a>
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Order Date</th>
                <th>Status</th>
                <th>Total</th>
                <th style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@order.Status</td>
                    <td>@order.TotalAmount.ToString("C")</td>
                    <td>
                        <a asp-area="Orders" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-sm btn-info">
                            Details
                        </a>

                        @if (order.Status != Bookstore.Module.Orders.Models.OrderStatus.Cancelled)
                        {
                            <form asp-area="Orders" asp-controller="Orders" asp-action="Cancel" asp-route-id="@order.Id"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure you want to cancel this order?');">
                                    Cancel
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>