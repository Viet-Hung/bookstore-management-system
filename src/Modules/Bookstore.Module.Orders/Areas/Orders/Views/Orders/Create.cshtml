@model Bookstore.Module.Orders.ViewModels.CreateOrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<div class="container mt-4">
    <h1>Create Order</h1>

    <form asp-area="Orders" asp-controller="Orders" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Book</label>
            <select asp-for="Items[0].BookId" class="form-select">
                <option value="">-- Select book --</option>
                @foreach (var book in Model.AvailableBooks)
                {
                    <option value="@book.Id">
                        @book.Title - Stock: @book.StockQuantity - Price: @book.Price
                    </option>
                }
            </select>
            <span asp-validation-for="Items[0].BookId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Quantity</label>
            <input asp-for="Items[0].Quantity" class="form-control" />
            <span asp-validation-for="Items[0].Quantity" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Create Order</button>
        <a asp-area="Orders" asp-controller="Orders" asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}