@model Bookstore.Module.Catalog.ViewModels.CreateCategoryViewModel

@{
    ViewData["Title"] = "Create Category";
}

<div class="container mt-4">

    <h1>Create Category</h1>

    <form asp-area="Catalog" asp-controller="Categories" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-area="Catalog" asp-controller="Categories" asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </form>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</div>