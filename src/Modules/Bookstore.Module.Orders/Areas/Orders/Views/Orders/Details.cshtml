@model Bookstore.Module.Orders.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-4">
    <h1>Order Details</h1>

    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Order Date:</strong> @Model.OrderDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Status:</strong> @Model.Status</p>
            <p><strong>Total:</strong> @Model.TotalAmount.ToString("C")</p>
        </div>
    </div>

    <h3>Items</h3>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Book</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Line Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Book?.Title</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-area="Orders" asp-controller="Orders" asp-action="Index" class="btn btn-secondary">
        Back
    </a>
</div>