@model List<Bookstore.Module.Catalog.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Categories</h1>
        <a asp-area="Catalog" asp-controller="Categories" asp-action="Create" class="btn btn-primary">
            Create Category
        </a>
    </div>

    @* @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    } *@

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>
                        @if (category.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-area="Catalog" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.Id"
                               class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        @if (category.IsActive)
                        {
                            <form asp-area="Catalog" asp-controller="Categories" asp-action="Deactivate"
                                  asp-route-id="@category.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure you want to deactivate this category?');">
                                    Deactivate
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>