@model List<Bookstore.Module.Catalog.Models.Category>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="container-fluid px-0">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h1 class="h3 fw-bold mb-1">Categories</h1>
                        <p class="text-muted mb-0">
                            Manage book categories and control which categories are active in the catalog.
                        </p>
                    </div>

                    <a asp-area="Catalog" asp-controller="Categories" asp-action="Create" class="btn btn-primary px-4">
                        + Create Category
                    </a>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (Model == null || !Model.Any())
                {
                    <div class="text-center border rounded-4 p-5 bg-light">
                        <h2 class="h5 fw-semibold mb-2">No categories found</h2>
                        <p class="text-muted mb-4">
                            Start by creating your first category for the bookstore catalog.
                        </p>
                        <a asp-area="Catalog" asp-controller="Categories" asp-action="Create" class="btn btn-primary">
                            Create Category
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Name</th>
                                    <th>Status</th>
                                    <th class="text-end pe-3" style="width: 260px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var category in Model)
                                {
                                    <tr>
                                        <td class="ps-3 fw-medium">
                                            @category.Name
                                        </td>
                                        <td>
                                            @if (category.IsActive)
                                            {
                                                <span
                                                    class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                    Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span
                                                    class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                                    Inactive
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end pe-3">
                                            <a asp-area="Catalog" asp-controller="Categories" asp-action="Edit"
                                                   asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary me-2">
                                                Edit
                                            </a>

                                            @if (category.IsActive)
                                            {
                                                <form asp-area="Catalog" asp-controller="Categories" asp-action="Deactivate"
                                                      asp-route-id="@category.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Deactivate
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
